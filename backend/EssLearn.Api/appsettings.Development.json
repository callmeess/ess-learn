{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "VideoStorage": {
    "DownloadPath": "../../downloads"
  },
  "BlobStorage": {
    "Endpoint": "localhost:9090",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSSL": false,
    "Region": "us-east-1",
    "Buckets": {
      "Videos": "esslearn-videos",
      "Images": "esslearn-images",
      "Icons": "esslearn-icons",
      "Temp": "esslearn-temp"
    },
    "Timeouts": {
      "UploadTimeoutSeconds": 3600,
      "DownloadTimeoutSeconds": 1800,
      "VerificationTimeoutSeconds": 300
    }
  }
}
