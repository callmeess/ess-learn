{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=esslearn;Username=esslearn;Password=esslearn",
    "Redis": "localhost:6379"
  },
  "YouTube": {
    "ApiKey": "YOUR_YOUTUBE_API_KEY"
  },
  "VideoStorage": {
    "DownloadPath": "/app/downloads"
  },
  "BlobStorage": {
    "Endpoint": "minio:9000",
    "AccessKey": "${MINIO_ROOT_USER}",
    "SecretKey": "${MINIO_ROOT_PASSWORD}",
    "UseSSL": false,
    "Region": "us-east-1",
    "Buckets": {
      "Videos": "esslearn-videos",
      "Images": "esslearn-images",
      "Icons": "esslearn-icons",
      "Temp": "esslearn-temp"
    },
    "Timeouts": {
      "UploadTimeoutSeconds": 3600,
      "DownloadTimeoutSeconds": 1800,
      "VerificationTimeoutSeconds": 300
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
